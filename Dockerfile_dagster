FROM python:3.11-slim

# Control-plane image: dagster-webserver + dagster-daemon (no user code).
# Pin Dagster stack to the same versions as `requirements.lock.txt` / CI.

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    DAGSTER_HOME=/opt/dagster/dagster_home

COPY requirements.lock.txt ./

RUN python -m pip install --upgrade pip \
  && grep -E '^(dagster==|dagster-webserver==|dagster-postgres==|dagster-docker==)' requirements.lock.txt \
    | xargs python -m pip install

RUN mkdir -p "$DAGSTER_HOME"

WORKDIR /opt/dagster/app

COPY scripts/dagster_control_plane_entrypoint.sh /usr/local/bin/dagster-control-plane-entrypoint
RUN chmod +x /usr/local/bin/dagster-control-plane-entrypoint

